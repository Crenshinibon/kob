{
	"name": "kob",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "bun@1.3.9",
	"scripts": {
		"dev": "export ORIGIN=http://localhost:5173 && vite dev",
		"build": "bun run db:push && vite build",
		"preview": "vite preview",
		"prepare": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide && svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:unit": "vitest run",
		"test:e2e": "playwright test",
		"playwright": "playwright test",
		"test": "npm run test:unit && npm run test:e2e",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"db:push": "bun scripts/db-push.ts",
		"db:cleanup-neon-branches": "bun scripts/cleanup-neon-branches.ts",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"auth:schema": "bunx @better-auth/cli generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes",
		"db:wipe": "bun scripts/wipe-tournaments.ts",
		"db:cleanup": "bun scripts/cleanup-old-tournaments.ts"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.60.0",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/bun": "^1.3.14",
		"@types/node": "^25.9.2",
		"@types/qrcode": "^1.5.6",
		"better-auth": "^1.6.14",
		"dotenv": "^17.4.2",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"esbuild": "^0.28.0",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"postgres": "^3.4.9",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"svelte": "^5.56.2",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	},
	"dependencies": {
		"@inlang/paraglide-js": "^2.18.2",
		"@neondatabase/serverless": "^1.1.0",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"qrcode": "^1.5.4",
		"valibot": "^1.4.1"
	},
	"trustedDependencies": [
		"esbuild"
	]
}
